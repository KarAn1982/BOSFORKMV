{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.bosforkmv.ru/schemas/lead.json",
  "title": "BosforLead",
  "type": "object",
  "required": ["form_id", "audience", "consent", "consent_version", "page_url"],
  "properties": {
    "form_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "audience": {
      "enum": ["b2c", "developer", "architect", "corporate"]
    },
    "name": {
      "type": "string",
      "maxLength": 120
    },
    "phone": {
      "type": "string",
      "maxLength": 32
    },
    "email": {
      "type": "string",
      "format": "email",
      "maxLength": 254
    },
    "company": {
      "type": "string",
      "maxLength": 200
    },
    "object_type": {
      "type": "string",
      "maxLength": 120
    },
    "region": {
      "type": "string",
      "maxLength": 160
    },
    "message": {
      "type": "string",
      "maxLength": 5000
    },
    "consent": {
      "const": true
    },
    "consent_version": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "page_url": {
      "type": "string",
      "format": "uri",
      "maxLength": 2048
    },
    "referrer": {
      "type": "string",
      "maxLength": 2048
    },
    "utm_source": {
      "type": "string",
      "maxLength": 200
    },
    "utm_medium": {
      "type": "string",
      "maxLength": 200
    },
    "utm_campaign": {
      "type": "string",
      "maxLength": 200
    },
    "utm_content": {
      "type": "string",
      "maxLength": 200
    },
    "utm_term": {
      "type": "string",
      "maxLength": 200
    },
    "yclid": {
      "type": "string",
      "maxLength": 200
    },
    "gclid": {
      "type": "string",
      "maxLength": 200
    },
    "client_id": {
      "type": "string",
      "maxLength": 200
    }
  },
  "anyOf": [
    {
      "required": ["phone"]
    },
    {
      "required": ["email"]
    }
  ],
  "additionalProperties": false
}
